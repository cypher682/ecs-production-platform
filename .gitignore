# =============================================================
# Terraform
# =============================================================
.terraform/
*.tfstate
*.tfstate.*
*.tfstate.backup
crash.log
crash.*.log
.terraform.lock.hcl

# Terraform execution plans (contain state — never commit)
*.tfplan

# Terraform variable files (may contain secrets)
*.tfvars
*.tfvars.json
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc

# =============================================================
# Secrets & Credentials — NEVER COMMIT
# =============================================================
*.pem
*.key
*.p12
*.pfx
.env
.env.*
*.secret
*secret*
*password*
*credentials*
.db-password-backup.txt
aws-credentials.txt

# =============================================================
# AWS CLI / SDK
# =============================================================
# Don't commit local AWS credential overrides
.aws/

# =============================================================
# Docker
# =============================================================
# Build artifacts (not source)
*.tar

# =============================================================
# Python
# =============================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
venv/
env/
.venv/
*.egg-info/
dist/
build/
.pytest_cache/
.coverage
htmlcov/

# =============================================================
# Images — ignore by default, allow specific committed folders
# =============================================================
*.png
*.jpg
*.jpeg
*.gif
*.mp4

# Exceptions — these image folders ARE committed intentionally
!docs/assets/
!docs/assets/**
!docs/evidence/screenshots/
!docs/evidence/screenshots/**

# =============================================================
# Personal notes & learning material (not for repo)
# =============================================================
LEARNING.md
notes.md
TODO.md
scratch/
tmp/

# =============================================================
# IDEs & OS
# =============================================================
.vscode/
.idea/
.qodo/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# =============================================================
# Logs
# =============================================================
*.log
logs/
